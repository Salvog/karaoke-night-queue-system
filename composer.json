{
    "name": "karaoke-night/queue-system",
    "description": "Karaoke Night Queue System",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "laravel/pint": "^1.13",
        "phpstan/phpstan": "^2.1",
        "mockery/mockery": "^1.6",
        "larastan/larastan": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "test": "php artisan test",
        "stan": "php -d memory_limit=512M vendor/bin/phpstan analyse --no-progress",
        "pint": "pint",
        "secrets": "bash -lc \"if command -v gitleaks >/dev/null 2>&1; then gitleaks detect --no-banner; else echo gitleaks not installed, skipping; fi\"",
        "audit-safe": "composer audit --locked --ignore-unreachable"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
